APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ------------------------------------------------------------------------------
# Supabase Storage
# Used by App\Services\SupabaseService for file uploads, downloads, and deletes.
# Find these values in your Supabase project → Settings → API.
# ------------------------------------------------------------------------------

# Your Supabase project URL (e.g. https://xyzabc.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — used as the default apikey header for read operations.
# Safe to expose to the browser; Row-Level Security policies still apply.
SUPABASE_KEY=your-supabase-anon-key

# Service role key — bypasses Row-Level Security for privileged file writes.
# Keep this secret. Never expose it to the browser or commit it to version control.
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------------------------
# ESP32 RFID Hardware Integration
# Shared secret verified by VerifyEsp32ApiKey middleware on all /api/rfid/* routes
# that originate from ESP32 devices. Set the same value on the physical device.
# Keep this secret and rotate it if a device is compromised.
# ------------------------------------------------------------------------------
ESP32_API_KEY=your-esp32-api-key

# ------------------------------------------------------------------------------
# Firebase Sync
# Controls whether real-time Firebase sync is active (true/false).
# Defaults to false. Set to true only when Firebase is fully configured.
# See config/app.php → firebase_sync_enabled.
# ------------------------------------------------------------------------------
FIREBASE_SYNC_ENABLED=false
